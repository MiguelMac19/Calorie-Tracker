<%- include('../partials/header') %>
<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Food Database Browser</h2>
    <a href="/admin/foods/new" class="btn btn-success">+ Add New Food</a>
  </div>

  <form action="/admin/foods" method="GET" class="mb-4">
    <div class="input-group">
      <input type="text" name="q" class="form-control" placeholder="Search foods..." value="<%= query %>">
      <button class="btn btn-primary">Search</button>
    </div>
  </form>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Serving</th>
        <th>Calories</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% foods.forEach(food => { %>
        <tr>
          <td><%= food.name %></td>
          <td><%= food.servingSize %> <%= food.servingUnit %></td>
          <td><%= food.calories %> cal</td>
          <td>
            <a href="/admin/foods/<%= food.id %>/edit" class="btn btn-sm btn-info text-white">Edit</a>
            <form action="/admin/foods/<%= food.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this food?')">
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>