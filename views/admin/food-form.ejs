<%- include('../partials/header') %>
<div class="container my-4" style="max-width: 600px;">
  <h2><%= food ? 'Edit' : 'Add' %> Food Item</h2>
  <div class="card">
    <div class="card-body">
      <form action="/admin/foods<%= food ? '/' + food.id : '' %>" method="POST">
        <div class="mb-3">
          <label class="form-label">Food Name</label>
          <input type="text" name="name" class="form-control" value="<%= food ? food.name : '' %>" required>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Calories</label>
            <input type="number" name="calories" class="form-control" value="<%= food ? food.calories : '' %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Serving Size</label>
            <input type="number" step="0.1" name="servingSize" class="form-control" value="<%= food ? food.servingSize : 1 %>" required>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Serving Unit (e.g. cup, 100g)</label>
          <input type="text" name="servingUnit" class="form-control" value="<%= food ? food.servingUnit : '' %>" required>
        </div>
        <button class="btn btn-primary w-100">Save Food</button>
        <a href="/admin/foods" class="btn btn-link w-100 mt-2 text-muted">Cancel</a>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>