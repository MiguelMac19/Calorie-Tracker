<%- include('../partials/header') %>
<div class="container my-4" style="max-width: 600px;">
  <h2><%= food ? 'Edit' : 'Add' %> Food Item</h2>
  <div class="card">
    <div class="card-body">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form action="/admin/foods<%= food ? '/' + food.id : '' %>" method="POST">
        <div class="mb-3">
          <label class="form-label">Food Name</label>
          <input type="text" name="name" class="form-control" value="<%= food ? food.name : '' %>" required>
        </div>
        <div class="row">
          <div class="col-md-4 mb-3">
            <label class="form-label">Calories</label>
            <input type="number" name="calories" class="form-control" value="<%= food ? food.calories : '' %>" required>
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label">Serving Size</label>
            <input type="number" step="0.1" name="servingSize" class="form-control" value="<%= food ? food.servingSize : 1 %>" required>
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label">Serving Unit</label>
            <input type="text" name="servingUnit" class="form-control" placeholder="e.g. cup, 100g" value="<%= food ? food.servingUnit : '' %>" required>
          </div>
        </div>

        <hr>
        <h6 class="text-muted mb-3">Macronutrients <span class="small">(per serving, optional)</span></h6>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Protein (g)</label>
            <input type="number" step="0.1" min="0" name="protein" class="form-control" placeholder="0" value="<%= food && food.protein != null ? food.protein : '' %>">
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Carbohydrates (g)</label>
            <input type="number" step="0.1" min="0" name="carbs" class="form-control" placeholder="0" value="<%= food && food.carbs != null ? food.carbs : '' %>">
          </div>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Fat (g)</label>
            <input type="number" step="0.1" min="0" name="fat" class="form-control" placeholder="0" value="<%= food && food.fat != null ? food.fat : '' %>">
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Fiber (g)</label>
            <input type="number" step="0.1" min="0" name="fiber" class="form-control" placeholder="0" value="<%= food && food.fiber != null ? food.fiber : '' %>">
          </div>
        </div>

        <button class="btn btn-primary w-100">Save Food</button>
        <a href="/admin/foods" class="btn btn-link w-100 mt-2 text-muted">Cancel</a>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
