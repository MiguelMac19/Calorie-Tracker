<%- include('../partials/header') %>

<div class="page-header text-center">
  <div class="container mt-4">
    <h1>Search Food Database</h1>
    <p><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
  </div>
</div>

<div class="container" style="max-width: 700px">
  <div class="my-4">
    <div class="card mb-4">
      <div class="card-body">
        <form action="/food/search" method="GET">
          <label class="form-label">Search for a food item</label>
          <div class="input-group mb-2">
            <input class="form-control" type="text" name="q" placeholder="e.g. apple, chicken breast..." value="<%= query %>" required>
            <button class="btn btn-info text-white" type="submit">Search</button>
          </div>
          <div class="form-text">Searches the local database and USDA FoodData Central.</div>
        </form>
      </div>
    </div>

    <% if (selectedFood) { %>
      <div class="card mb-4 border-primary">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
          <h4 class="mb-0"><%= selectedFood.name %></h4>
          <% if (selectedFood.source === 'usda') { %>
            <span class="badge bg-success">USDA</span>
          <% } else if (selectedFood.source === 'custom') { %>
            <span class="badge bg-warning text-dark">Custom</span>
          <% } else { %>
            <span class="badge bg-light text-dark">Local</span>
          <% } %>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <span class="text-muted">Standard serving:</span>
            <strong><%= selectedFood.servingSize %> <%= selectedFood.servingUnit %></strong>
            <span class="h4 fw-bold d-block mt-1"><%= selectedFood.calories %> cal <small class="text-muted">per serving</small></span>
          </div>

          <% if (user && (user.role === 'premium' || user.role === 'admin')) { %>
            <% if (selectedFood.protein != null || selectedFood.carbs != null || selectedFood.fat != null || selectedFood.fiber != null) { %>
              <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="macro-badge macro-protein">Protein: <%= selectedFood.protein != null ? selectedFood.protein + 'g' : 'N/A' %></span>
                <span class="macro-badge macro-carbs">Carbs: <%= selectedFood.carbs != null ? selectedFood.carbs + 'g' : 'N/A' %></span>
                <span class="macro-badge macro-fat">Fat: <%= selectedFood.fat != null ? selectedFood.fat + 'g' : 'N/A' %></span>
                <span class="macro-badge macro-fiber">Fiber: <%= selectedFood.fiber != null ? selectedFood.fiber + 'g' : 'N/A' %></span>
              </div>
            <% } %>
          <% } %>

          <form action="/food/log" method="POST">
            <input type="hidden" name="foodId" value="<%= selectedFood.id %>">
            <input type="hidden" name="foodSource" value="<%= selectedFood.source %>">
            <input type="hidden" name="foodName" value="<%= selectedFood.name %>">
            <input type="hidden" name="foodCalories" value="<%= selectedFood.calories %>">
            <input type="hidden" name="foodServingSize" value="<%= selectedFood.servingSize %>">
            <input type="hidden" name="foodServingUnit" value="<%= selectedFood.servingUnit %>">
            <input type="hidden" name="foodProtein" value="<%= selectedFood.protein %>">
            <input type="hidden" name="foodCarbs" value="<%= selectedFood.carbs %>">
            <input type="hidden" name="foodFat" value="<%= selectedFood.fat %>">
            <input type="hidden" name="foodFiber" value="<%= selectedFood.fiber %>">
            
            <div class="mb-3">
              <label class="form-label">Number of Servings</label>
              <input class="form-control" type="number" name="servings" value="1" min="0.1" step="0.1" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Meal Type</label>
              <select class="form-select" name="mealType" required>
                <option value="">— Select meal type —</option>
                <option value="breakfast">Breakfast</option>
                <option value="lunch">Lunch</option>
                <option value="dinner">Dinner</option>
                <option value="snack">Snack</option>
              </select>
            </div>

            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-info text-white btn-lg">Add to Log</button>
              <a href="/food/search?q=<%= query %>" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    <% } %>

    <% if (results.length > 0) { %>
      <div class="text-muted small mb-2">
        Showing <strong><%= results.length %> results</strong> for "<%= query %>"
      </div>
      <div class="card">
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Food Name</th>
                <th>Serving</th>
                <th>Calories</th>
                <th>Source</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% results.forEach(food => { %>
                <tr>
                  <td class="fw-semibold"><%= food.name %></td>
                  <td class="text-muted"><%= food.servingSize %> <%= food.servingUnit %></td>
                  <td><%= food.calories %> cal</td>
                  <td>
                    <% if (food.source === 'usda') { %>
                      <span class="badge bg-success" style="font-size: 11px;">USDA</span>
                    <% } else if (food.source === 'custom') { %>
                      <span class="badge bg-warning text-dark" style="font-size: 11px;">Custom</span>
                    <% } else { %>
                      <span class="badge bg-secondary" style="font-size: 11px;">Local</span>
                    <% } %>
                  </td>
                  <td>
                    <a href="/food/<%= food.id %>?q=<%= query %>" class="btn btn-outline-info btn-sm">Select</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else if (query) { %>
      <div class="alert alert-warning">No foods found matching "<%= query %>".</div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
