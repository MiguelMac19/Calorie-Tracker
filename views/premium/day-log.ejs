<%- include('../partials/header') %>

<div class="page-header text-center">
  <div class="container mt-4">
    <h1>Food Log</h1>
    <p><%= new Date(date + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
  </div>
</div>

<div class="container my-4" style="max-width: 850px;">

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <!-- Success Messages -->
  <% if (typeof success !== 'undefined') { %>
    <% /* success passed via query string, handled in controller */ %>
  <% } %>

  <a href="/premium/history" class="btn btn-outline-secondary mb-3">&larr; Back to History</a>

  <!-- Summary Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <div class="text-muted small fw-bold">TOTAL CALORIES</div>
          <div class="stat-value"><%= totalCalories %></div>
          <div class="text-muted small">cal</div>
        </div>
      </div>
    </div>
    <% if (isPremium) { %>
      <div class="col-md-8">
        <div class="card">
          <div class="card-body">
            <div class="text-muted small fw-bold mb-2">MACRONUTRIENTS</div>
            <div class="d-flex flex-wrap gap-2">
              <div class="flex-fill text-center p-2 rounded" style="background: #dbeafe;">
                <div class="fw-bold" style="color: #1e40af;"><%= macros.protein %>g</div>
                <div class="small text-muted">Protein</div>
              </div>
              <div class="flex-fill text-center p-2 rounded" style="background: #fef3c7;">
                <div class="fw-bold" style="color: #92400e;"><%= macros.carbs %>g</div>
                <div class="small text-muted">Carbs</div>
              </div>
              <div class="flex-fill text-center p-2 rounded" style="background: #fce7f3;">
                <div class="fw-bold" style="color: #9d174d;"><%= macros.fat %>g</div>
                <div class="small text-muted">Fat</div>
              </div>
              <div class="flex-fill text-center p-2 rounded" style="background: #d1fae5;">
                <div class="fw-bold" style="color: #065f46;"><%= macros.fiber %>g</div>
                <div class="small text-muted">Fiber</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Food Entries -->
  <% if (logs.length === 0) { %>
    <div class="alert alert-info text-center">No food logged on this date.</div>
  <% } else { %>
    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>Food</th>
              <th>Servings</th>
              <th>Meal</th>
              <th>Calories</th>
              <% if (isPremium) { %>
                <th>Protein</th>
                <th>Carbs</th>
                <th>Fat</th>
                <th>Fiber</th>
              <% } %>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(log => { %>
              <tr>
                <td class="fw-semibold"><%= log.Food ? log.Food.name : 'Unknown' %></td>
                <td><%= log.servings %></td>
                <td><span class="badge-meal"><%= log.mealType %></span></td>
                <td><%= log.totalCalories %> cal</td>
                <% if (isPremium) { %>
                  <td>
                    <% if (log.Food && log.Food.protein != null) { %>
                      <span class="macro-badge macro-protein"><%= Math.round(log.Food.protein * log.servings * 10) / 10 %>g</span>
                    <% } else { %>
                      <span class="text-muted">N/A</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (log.Food && log.Food.carbs != null) { %>
                      <span class="macro-badge macro-carbs"><%= Math.round(log.Food.carbs * log.servings * 10) / 10 %>g</span>
                    <% } else { %>
                      <span class="text-muted">N/A</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (log.Food && log.Food.fat != null) { %>
                      <span class="macro-badge macro-fat"><%= Math.round(log.Food.fat * log.servings * 10) / 10 %>g</span>
                    <% } else { %>
                      <span class="text-muted">N/A</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (log.Food && log.Food.fiber != null) { %>
                      <span class="macro-badge macro-fiber"><%= Math.round(log.Food.fiber * log.servings * 10) / 10 %>g</span>
                    <% } else { %>
                      <span class="text-muted">N/A</span>
                    <% } %>
                  </td>
                <% } %>
                <td>
                  <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#editModal-<%= log.id %>">Edit</button>
                  <form action="/premium/history/<%= date %>/delete/<%= log.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this entry? This action cannot be undone.')">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                </td>
              </tr>

              <!-- Edit Modal for this entry -->
              <div class="modal fade" id="editModal-<%= log.id %>" tabindex="-1">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title">Edit Entry: <%= log.Food ? log.Food.name : 'Unknown' %></h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/premium/history/<%= date %>/edit/<%= log.id %>" method="POST">
                      <div class="modal-body">
                        <div class="mb-3">
                          <label class="form-label">Food</label>
                          <input type="text" class="form-control" value="<%= log.Food ? log.Food.name : 'Unknown' %>" disabled>
                          <div class="form-text">Food item cannot be changed. Delete and re-log to change the food.</div>
                        </div>
                        <div class="mb-3">
                          <label class="form-label">Number of Servings</label>
                          <input type="number" name="servings" class="form-control" value="<%= log.servings %>" min="0.1" step="0.1" required>
                        </div>
                        <div class="mb-3">
                          <label class="form-label">Meal Type</label>
                          <select name="mealType" class="form-select" required>
                            <option value="breakfast" <%= log.mealType === 'breakfast' ? 'selected' : '' %>>Breakfast</option>
                            <option value="lunch" <%= log.mealType === 'lunch' ? 'selected' : '' %>>Lunch</option>
                            <option value="dinner" <%= log.mealType === 'dinner' ? 'selected' : '' %>>Dinner</option>
                            <option value="snack" <%= log.mealType === 'snack' ? 'selected' : '' %>>Snack</option>
                          </select>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-info text-white">Save Changes</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="total-row">
        Total: <%= totalCalories %> calories
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
