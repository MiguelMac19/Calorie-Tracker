<%- include('../partials/header') %>

<div class="page-header text-center">
  <div class="container mt-4">
    <h1>Create Your Account</h1>
    <p>Start tracking your calories for free</p>
  </div>
</div>

<div class="container my-4" style="max-width: 450px;">
  <div class="card">
    <div class="card-body p-4">

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/register" method="POST">
        <div class="mb-3">
          <label class="form-label">Full Name</label>
          <input type="text" name="name" class="form-control" placeholder="John Doe" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="At least 8 characters" required>
          <div class="form-text">Must be at least 8 characters with at least 1 number.</div>
        </div>
        <div class="mb-3">
          <label class="form-label">Confirm Password</label>
          <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter your password" required>
        </div>
        <div class="d-grid">
          <button type="submit" class="btn btn-info text-white btn-lg">Create Account</button>
        </div>
      </form>

      <div class="text-center mt-3">
        <a href="/login" class="link-blue">Already have an account? Log in</a>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
