<%- include('../partials/header') %>

<div class="page-header text-center">
  <div class="container mt-4">
    <h1>Welcome Back</h1>
    <p>Log in to your CalorieTrack account</p>
  </div>
</div>

<div class="container my-4" style="max-width: 450px;">
  <div class="card">
    <div class="card-body p-4">

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (registered) { %>
        <div class="alert alert-success">Account created successfully! Please log in.</div>
      <% } %>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
        </div>
        <div class="d-grid">
          <button type="submit" class="btn btn-info text-white btn-lg">Log In</button>
        </div>
      </form>

      <div class="text-center mt-3">
        <a href="/register" class="link-blue">Don't have an account? Sign up</a>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
