<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CalorieTrack</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark mb-4">
  <div class="container">
    <a class="navbar-brand" href="/">
      <span>Calorie</span>Track
    </a>
    
    <div class="navbar-nav ms-auto align-items-center">
      <% if (user) { %>
        <a class="nav-link text-white me-3" href="/dashboard">Dashboard</a>
        <a class="nav-link text-white me-3" href="/food/search">Search Foods</a>
        
        <% if (user.role === 'premium' || user.role === 'admin') { %>
          <a class="nav-link text-white me-3" href="/premium/history">History</a>
        <% } %>
        
        <% if (user.role === 'admin') { %>
          <a class="nav-link text-white me-3" href="/admin">Admin</a>
        <% } %>
        
        <span class="navbar-text text-light me-3 small">Hi, <%= user.name %></span>
        
        <form action="/logout" method="POST" class="d-inline">
          <button type="submit" class="btn btn-sm btn-outline-light">Log Out</button>
        </form>
      <% } else { %>
        <a class="nav-link text-white me-3" href="/login">Log In</a>
        <a class="btn btn-info btn-sm text-white" href="/register">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>