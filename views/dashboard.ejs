<%- include('partials/header') %>

<div class="page-header text-center">
  <div class="container mt-4">
    <h1>Your Dashboard</h1>
    <p><%= new Date(today + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
  </div>
</div>

<div class="container my-4" style="max-width: 800px;">

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <!-- Stat Cards - consistent sizing -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card text-center h-100">
        <div class="card-body d-flex flex-column justify-content-center" style="min-height: 100px;">
          <div class="text-muted small fw-bold">TODAY'S DATE</div>
          <div class="stat-value" style="font-size: 28px;"><%= new Date(today + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center h-100">
        <div class="card-body d-flex flex-column justify-content-center" style="min-height: 100px;">
          <div class="text-muted small fw-bold">CALORIES TODAY</div>
          <div class="stat-value" style="font-size: 28px;"><%= totalCalories %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center h-100">
        <div class="card-body d-flex flex-column justify-content-center" style="min-height: 100px;">
          <div class="text-muted small fw-bold">ENTRIES LOGGED</div>
          <div class="stat-value" style="font-size: 28px;"><%= logs.length %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Upgrade banner for free users -->
  <% if (user && user.role === 'free') { %>
    <div class="alert alert-warning d-flex justify-content-between align-items-center">
      <span>Upgrade to <strong>Premium</strong> for macronutrient tracking, 30-day history, and custom foods!</span>
      <a href="/premium/upgrade" class="btn btn-warning btn-sm fw-bold">Upgrade Now</a>
    </div>
  <% } %>

  <!-- Food Log Table -->
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Today's Food Log</h5>
      <a href="/food/search" class="btn btn-info btn-sm text-white">+ Add Food</a>
    </div>
    <div class="card-body p-0">
      <% if (logs.length === 0) { %>
        <div class="text-center py-5">
          <p class="text-muted mb-3">No food logged today.</p>
          <a href="/food/search" class="btn btn-info text-white">Add Food</a>
        </div>
      <% } else { %>
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>Food</th>
              <th>Servings</th>
              <th>Meal</th>
              <th>Calories</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(log => { %>
              <tr>
                <td class="fw-semibold"><%= log.Food ? log.Food.name : 'Unknown' %></td>
                <td><%= log.servings %></td>
                <td><span class="badge-meal"><%= log.mealType %></span></td>
                <td><%= log.totalCalories %> cal</td>
                <td>
                  <form action="/dashboard/remove/<%= log.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Remove this entry?')">
                    <button class="btn btn-sm btn-outline-danger">Remove</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="total-row">
          Total: <%= totalCalories %> calories
        </div>
      <% } %>
    </div>
  </div>

  <!-- Macronutrient Summary -->
  <% if (logs.length > 0) { %>
    <div class="card mt-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h6 class="mb-0 fw-bold text-muted">TODAY'S MACRONUTRIENTS</h6>
          <% if (user && user.role === 'free') { %>
            <a href="/premium/upgrade" class="badge bg-warning text-dark text-decoration-none" style="font-size: 11px;">PREMIUM FEATURE</a>
          <% } %>
        </div>
        <% if (user && (user.role === 'premium' || user.role === 'admin')) { %>
          <!-- Premium: show real values -->
          <div class="d-flex flex-wrap gap-2">
            <div class="flex-fill text-center p-2 rounded" style="background: #dbeafe;">
              <div class="fw-bold" style="color: #1e40af; font-size: 20px;"><%= macros.protein %>g</div>
              <div class="small text-muted">Protein</div>
            </div>
            <div class="flex-fill text-center p-2 rounded" style="background: #fef3c7;">
              <div class="fw-bold" style="color: #92400e; font-size: 20px;"><%= macros.carbs %>g</div>
              <div class="small text-muted">Carbs</div>
            </div>
            <div class="flex-fill text-center p-2 rounded" style="background: #fce7f3;">
              <div class="fw-bold" style="color: #9d174d; font-size: 20px;"><%= macros.fat %>g</div>
              <div class="small text-muted">Fat</div>
            </div>
            <div class="flex-fill text-center p-2 rounded" style="background: #d1fae5;">
              <div class="fw-bold" style="color: #065f46; font-size: 20px;"><%= macros.fiber %>g</div>
              <div class="small text-muted">Fiber</div>
            </div>
          </div>
        <% } else { %>
          <!-- Free: show blurred placeholder values -->
          <div class="d-flex flex-wrap gap-2 position-relative">
            <div class="flex-fill text-center p-2 rounded" style="background: #dbeafe; filter: blur(5px); user-select: none;">
              <div class="fw-bold" style="color: #1e40af; font-size: 20px;">??g</div>
              <div class="small text-muted">Protein</div>
            </div>
            <div class="flex-fill text-center p-2 rounded" style="background: #fef3c7; filter: blur(5px); user-select: none;">
              <div class="fw-bold" style="color: #92400e; font-size: 20px;">??g</div>
              <div class="small text-muted">Carbs</div>
            </div>
            <div class="flex-fill text-center p-2 rounded" style="background: #fce7f3; filter: blur(5px); user-select: none;">
              <div class="fw-bold" style="color: #9d174d; font-size: 20px;">??g</div>
              <div class="small text-muted">Fat</div>
            </div>
            <div class="flex-fill text-center p-2 rounded" style="background: #d1fae5; filter: blur(5px); user-select: none;">
              <div class="fw-bold" style="color: #065f46; font-size: 20px;">??g</div>
              <div class="small text-muted">Fiber</div>
            </div>
          </div>
          <div class="text-center mt-2">
            <a href="/premium/upgrade" class="link-blue small">Upgrade to Premium to see your macronutrient breakdown</a>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
